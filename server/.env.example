# Conexión a Postgres
DATABASE_URL=postgresql://mantelek:mantelek@localhost:5432/mantelek
# Ponlo en "true" si tu Postgres gestionado exige SSL (Render, Neon, etc.)
DATABASE_SSL=false

# Servidor
PORT=4000
# Origen(es) permitido(s) por CORS. En producción, la URL del frontend en Vercel.
# Puedes poner varios separados por coma.
CLIENT_ORIGIN=http://localhost:5173

# Seguridad — usa un valor largo y aleatorio en producción
JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=7d

# Almacenamiento de archivos.
# En producción apunta a un volumen/disco persistente montado, p. ej. /data/uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=15

# --- Notificaciones (Módulo 5) ---
# Sin RESEND_API_KEY los recordatorios NO se envían: se registran como
# "simulado" en la bitácora. El sistema funciona igual, pero nadie recibe nada.
# Consigue la key en https://resend.com (3.000 correos/mes gratis).
RESEND_API_KEY=
# Remitente. Para usar tu propio dominio hay que verificarlo en Resend.
# Sin dominio propio puedes usar el de pruebas: Mantelek <onboarding@resend.dev>
MAIL_FROM=Mantelek <onboarding@resend.dev>
# Copia oculta a Mantelek de cada recordatorio (opcional)
MAIL_BCC=
# Pon "false" para apagar el cron de recordatorios
REMINDERS_ENABLED=true
# Zona horaria del cron (días 10/15/20 a las 09:00)
TZ_CRON=America/Mexico_City
# URL del portal, se incluye como botón en los correos
PORTAL_URL=https://mantelek.vercel.app

# WhatsApp: preparado pero sin implementar (requiere plantillas aprobadas por Meta)
WHATSAPP_ENABLED=false
